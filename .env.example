# LLM 공급자 (하나만 설정해도 동작. 아무것도 없으면 fallback 요약으로 기본 화면 표시)
# 우선순위 기본 순서: aws → anthropic → openai. LLM_PROVIDER 로 맨 앞을 지정.

# --- Claude Platform on AWS (Anthropic 직접 운영, SigV4) ---
# IAM 자격증명 + region + workspace_id 필요. 모델 ID는 접두사 없는 그대로(claude-opus-4-8).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
ANTHROPIC_AWS_WORKSPACE_ID=
# AWS_MODEL 미지정 시 ANTHROPIC_MODEL 값을 그대로 사용
# AWS_MODEL=claude-opus-4-8

# --- 직접(first-party) Anthropic API 키 (sk-ant-...) ---
ANTHROPIC_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# 사용할 모델 (미지정 시 기본값 사용)
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o-mini

# LLM 우선순위 맨 앞 지정: aws | anthropic | openai (미지정 시 위 기본 순서)
LLM_PROVIDER=aws
